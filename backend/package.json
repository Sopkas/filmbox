{
  "name": "kinopulse-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:init": "node scripts/db-init.js",
    "lint": "eslint \"src/**/*.js\" \"scripts/**/*.js\"",
    "format": "prettier --write \"src/**/*.js\" \"scripts/**/*.js\" \"sql/**/*.sql\"",
    "format:check": "prettier --check \"src/**/*.js\" \"scripts/**/*.js\" \"sql/**/*.sql\"",
    "test:integration": "node --test \"test/integration/**/*.test.js\"",
    "check:syntax": "node --check src/app.js && node --check src/server.js && node --check src/routes/auth.routes.js && node --check src/routes/movies.routes.js && node --check src/routes/reviews.routes.js && node --check src/routes/collections.routes.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "supertest": "^7.1.0"
  }
}
